# Copy to .env.local (gitignored) and fill in.
#
# When VITE_PRICING_API_URL is set, the React app proxies Companies
# House lookups and quotes through the Momo pricing service at that
# URL (see pricing/api.py). Without it, the UI falls back to
# deterministic mock data and shows a "Mock data" badge on the
# UK Quick Start and Watch Demo pages.
#
# To run end-to-end locally:
#   1. cd pricing
#      pip install -r requirements-api.txt
#      export COMPANIES_HOUSE_API_KEY=your_key
#      uvicorn api:app --reload --port 8001
#   2. From the repo root:
#      cp .env.example .env.local
#      # edit if your service runs elsewhere
#      npm run dev
VITE_PRICING_API_URL=http://localhost:8001
